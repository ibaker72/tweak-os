# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — used by /api/v1/automate to bypass RLS when
# looking up site_configs. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# AI — Anthropic Claude (Haiku 4.5)
# ============================================================
# Used by:
#   src/lib/growth/brief-generator.ts
#   src/lib/growth/draft-generator.ts
#   src/lib/growth/keyword-research.ts
#   src/lib/leads/outreach.ts
ANTHROPIC_API_KEY=

# ============================================================
# Lead discovery — Google
# ============================================================
GOOGLE_PLACES_API_KEY=
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# ============================================================
# Lead Research — PageSpeed Insights (optional)
# ============================================================
# Used by /api/audit/run for higher rate limits on the
# Lighthouse-as-a-service endpoint. Free tier works without a key
# but is heavily rate-limited.
# TODO: add PAGESPEED_API_KEY env var for higher rate limits.
PAGESPEED_API_KEY=

# ============================================================
# OpenClaw automation hub — POST /api/v1/automate
# ============================================================
# Master Bearer token for forwarding leads to OpenClaw skills.
OPENCLAW_MASTER_KEY=
# Optional — defaults to https://api.clawhub.ai
OPENCLAW_API_BASE_URL=

# ============================================================
# Automation client (when this app calls into another hub)
# ============================================================
AUTOMATION_HUB_URL=
AUTOMATION_API_KEY=
