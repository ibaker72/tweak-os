# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — used by /api/v1/automate to bypass RLS when
# looking up site_configs. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# AI — Anthropic Claude (Haiku 4.5)
# ============================================================
# Used by:
#   src/lib/growth/brief-generator.ts
#   src/lib/growth/draft-generator.ts
#   src/lib/growth/keyword-research.ts
#   src/lib/leads/outreach.ts
ANTHROPIC_API_KEY=

# ============================================================
# Lead discovery — Google
# ============================================================
GOOGLE_PLACES_API_KEY=
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# ============================================================
# Lead Research — PageSpeed Insights (optional)
# ============================================================
# Used by /api/audit/run for higher rate limits on the
# Lighthouse-as-a-service endpoint. Free tier works without a key
# but is heavily rate-limited.
# TODO: add PAGESPEED_API_KEY env var for higher rate limits.
PAGESPEED_API_KEY=

# ============================================================
# OpenClaw automation hub — POST /api/v1/automate
# ============================================================
# Master Bearer token for forwarding leads to OpenClaw skills.
OPENCLAW_MASTER_KEY=
# Optional — defaults to https://api.clawhub.ai
OPENCLAW_API_BASE_URL=

# ============================================================
# OpenClaw API access (inbound) — /api/v1/openclaw/*
# ============================================================
# Server-side bearer token OpenClaw uses to authenticate against
# this app's read/update endpoints. Required by every route under
# /api/v1/openclaw — without it those endpoints return 500.
# Generate a long random string (e.g. `openssl rand -hex 32`) and
# store it in Vercel as OPENCLAW_API_TOKEN. Never expose to the client.
OPENCLAW_API_TOKEN=

# ============================================================
# Automation client (when this app calls into another hub)
# ============================================================
AUTOMATION_HUB_URL=
AUTOMATION_API_KEY=

# ============================================================
# Email — Resend (for /api/proposals/send)
# ============================================================
# Required to send proposal emails. Without it, the Email
# Proposal button returns a clear "not configured" error.
RESEND_API_KEY=
# The "from" address shown in the recipient's inbox. Must be a
# verified domain in Resend. Example: "Tweak & Build <hello@tweakandbuild.com>"
RESEND_FROM_EMAIL=
# Your own email — used as the destination for "Send Test To Myself"
# and as the reply-to address on outgoing proposal emails.
OWNER_EMAIL=

# ============================================================
# Twilio SMS — one-to-one business follow-up
# ============================================================
# Server-side only. NEVER expose any Twilio variable under
# NEXT_PUBLIC_*. Used by:
#   src/lib/sms/service.ts
#   src/app/api/sms/send/route.ts
#   src/app/api/webhooks/twilio/sms/route.ts
#
# Account SID and Auth Token from the Twilio Console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Prefer the Messaging Service SID — it routes through the A2P
# campaign and handles compliance auto-replies. Fall back to
# TWILIO_FROM_NUMBER when the service SID is not configured.
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=+18622984988
# Master gate. Keep this `false` until the Twilio A2P campaign
# is approved. While false, no Twilio API calls are made and the
# UI shows "SMS prepared — waiting for Twilio A2P approval."
# Flip to `true` in Vercel only after the campaign is approved.
SMS_SENDING_ENABLED=false
# Validate the X-Twilio-Signature header on inbound webhook
# requests. Leave `true` in production. Configure Twilio inbound
# SMS webhook to:
#   https://app.tweakandbuild.com/api/webhooks/twilio/sms
TWILIO_WEBHOOK_VALIDATE_SIGNATURE=true
# Keep SMS usage manual, low-volume, and relevant to active
# business follow-up. Do not build bulk or auto-blast features.
