# =============================================================
# Tweak & Build Lead Finder — Environment Variables
# Copy this file to .env.local for local development
# Set these in Vercel (or your host) for production
# =============================================================

# ---- Supabase (required) ------------------------------------
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- OpenAI (required for AI features) ----------------------
# platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# ---- Google APIs (required for lead discovery) --------------
# console.cloud.google.com → APIs & Services → Credentials
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_CUSTOM_SEARCH_API_KEY=your-google-custom-search-api-key
# programmablesearchengine.google.com → your search engine ID
GOOGLE_CUSTOM_SEARCH_CX=your-search-engine-cx-id

# ---- Automation Proxy (optional) ----------------------------
# Only needed if using the /api/v1/automate webhook with OpenClaw
OPENCLAW_MASTER_KEY=your-openclaw-master-key
OPENCLAW_API_BASE_URL=https://api.clawhub.ai
# Set any strong random string as your webhook secret
AUTOMATION_API_KEY=your-strong-secret-key-here
# Your deployed app URL (e.g. https://app.tweakandbuild.com)
AUTOMATION_HUB_URL=https://your-vercel-url.vercel.app
